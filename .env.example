# Leave empty for local development. Local DJ videos are read from:
# .local-media/assets
#
# For Vercel / sharing with other people, upload the same files to cloud storage
# and set this to the public folder root. The cloud folder must contain /assets/*.mp4.
#
# Example:
# NEXT_PUBLIC_MEDIA_BASE_URL=https://your-cdn.example.com
NEXT_PUBLIC_MEDIA_BASE_URL=

# Use "assets" for normal CDN paths like /assets/dj-soft.mp4.
# Use "flat" for GitHub Release assets like /dj-soft.mp4.
NEXT_PUBLIC_MEDIA_PATH_MODE=assets

# Keep this disabled for Vercel until the frame images are moved to CDN storage.
NEXT_PUBLIC_ENABLE_SINGER_FRAMES=false

# Keep this disabled for Vercel unless the alternate DJ videos are also on CDN.
NEXT_PUBLIC_ENABLE_DJ_VARIANTS=false
