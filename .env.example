# Leave empty for local development.
# In production, the app falls back to bundled demo media on GitHub raw.
# Set this after moving media to a CDN / Vercel Blob / Cloudflare R2.
# Example:
# NEXT_PUBLIC_MEDIA_BASE_URL=https://your-bucket.public.blob.vercel-storage.com
NEXT_PUBLIC_MEDIA_BASE_URL=

# Keep this disabled for Vercel until the frame images are moved to CDN storage.
NEXT_PUBLIC_ENABLE_SINGER_FRAMES=false

# Keep this disabled for Vercel unless the alternate DJ videos are also on CDN.
NEXT_PUBLIC_ENABLE_DJ_VARIANTS=false
